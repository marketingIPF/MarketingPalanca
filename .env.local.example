# Firebase client SDK (público, va en el bundle del navegador)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Firebase Admin SDK — SOLO servidor (API routes, scripts de seed)
# Pega aquí el JSON del service account en una sola línea.
FIREBASE_SERVICE_ACCOUNT=

# Webhook entrante de Slack (canal de contenido)
SLACK_WEBHOOK_URL=
